# Definindo os preços fixos
PRECO_ALCOOL = 2.89
PRECO_GASOLINA = 4.95

# Solicitando os dados ao usuário
litros = float(input('Digite a quantidade de litros vendidos: '))
tipo = input('Digite o tipo de combustível (A - Álcool / G - Gasolina): ').upper()

# Inicializando variáveis de controle
valor_total = 0
desconto = 0

if tipo == 'A':
    # Regras para o Álcool
    if litros <= 20:
        desconto = 0.03 # 3%
    else:
        desconto = 0.05 # 5%
    
    preco_com_desconto = PRECO_ALCOOL * (1 - desconto)
    valor_total = litros * preco_com_desconto

elif tipo == 'G':
    # Regras para a Gasolina
    if litros <= 20:
        desconto = 0.04 # 4%
    else:
        desconto = 0.06 # 6%
        
    preco_com_desconto = PRECO_GASOLINA * (1 - desconto)
    valor_total = litros * preco_com_desconto

else:
    print('Tipo de combustível inválido!')

# Exibindo o resultado final se o combustível for válido
if tipo == 'A' or tipo == 'G':
    print(f'Combustível: {tipo}')
    print(f'Litros: {litros}L')
    print(f'Valor a ser pago: R$ {valor_total:.2f}')